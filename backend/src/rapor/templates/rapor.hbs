<html>
  <head>
    <meta charset='UTF-8' />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Arial', sans-serif;
        padding: 40px;
        background: white;
      }
      .header {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 3px solid #333;
        padding-bottom: 20px;
      }
      .header h1 {
        font-size: 24px;
        margin-bottom: 5px;
        color: #2c3e50;
      }
      .header h2 {
        font-size: 18px;
        color: #555;
        font-weight: normal;
      }
      .student-info {
        margin: 30px 0;
        padding: 20px;
        background: #f8f9fa;
        border-radius: 8px;
      }
      .info-row {
        display: flex;
        margin-bottom: 10px;
      }
      .info-label {
        width: 150px;
        font-weight: bold;
        color: #2c3e50;
      }
      .info-value {
        flex: 1;
        color: #555;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 20px 0;
      }
      th,
      td {
        border: 1px solid #ddd;
        padding: 12px;
        text-align: left;
      }
      th {
        background-color: #2c3e50;
        color: white;
        font-weight: bold;
      }
      tr:nth-child(even) {
        background-color: #f8f9fa;
      }
      .grade-good {
        color: #27ae60;
        font-weight: bold;
      }
      .grade-medium {
        color: #f39c12;
        font-weight: bold;
      }
      .grade-low {
        color: #e74c3c;
        font-weight: bold;
      }
      .section-title {
        font-size: 18px;
        color: #2c3e50;
        margin: 30px 0 15px 0;
        padding-bottom: 10px;
        border-bottom: 2px solid #3498db;
      }
      .footer {
        margin-top: 50px;
        text-align: right;
      }
      .signature {
        margin-top: 80px;
        text-align: center;
      }
      .attendance-summary {
        display: flex;
        gap: 20px;
        margin: 10px 0;
      }
      .attendance-item {
        flex: 1;
        padding: 10px;
        background: #ecf0f1;
        border-radius: 5px;
        text-align: center;
      }
      .attendance-item strong {
        display: block;
        font-size: 24px;
        color: #2c3e50;
      }
    </style>
  </head>
  <body>
    <div class='header'>
      <h1>LAPORAN HASIL BELAJAR SISWA</h1>
      <h2>RAPOR AKADEMIK</h2>
    </div>

    <div class='student-info'>
      <div class='info-row'>
        <div class='info-label'>Nama Siswa:</div>
        <div class='info-value'>{{student.nama}}</div>
      </div>
      <div class='info-row'>
        <div class='info-label'>Email:</div>
        <div class='info-value'>{{student.email}}</div>
      </div>
      <div class='info-row'>
        <div class='info-label'>Tanggal Cetak:</div>
        <div class='info-value'>{{today}}</div>
      </div>
    </div>

    <div class='section-title'>Nilai Per Mata Pelajaran</div>
    <table>
      <thead>
        <tr>
          <th>Mata Pelajaran</th>
          <th>Kelas</th>
          <th>Nilai Akhir</th>
          <th>Predikat</th>
        </tr>
      </thead>
      <tbody>
        {{#each gradesPerClass}}
          <tr>
            <td>{{this.mataPelajaran}}</td>
            <td>{{this.kelasName}}</td>
            <td class='{{this.gradeClass}}'>{{this.score}}</td>
            <td class='{{this.gradeClass}}'>{{this.grade}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <div class='section-title'>Detail Komponen Nilai</div>
    {{#each gradesPerClass}}
      <h3 style='margin: 20px 0 10px 0; color: #34495e;'>{{this.mataPelajaran}}
        -
        {{this.kelasName}}</h3>
      <table>
        <thead>
          <tr>
            <th>Komponen</th>
            <th>Bobot (%)</th>
            <th>Nilai</th>
          </tr>
        </thead>
        <tbody>
          {{#each this.grades}}
            <tr>
              <td>{{this.komponen}}</td>
              <td>{{this.bobotPercent}}%</td>
              <td>{{this.nilaiFormatted}}</td>
            </tr>
          {{/each}}
        </tbody>
      </table>

      <div class='attendance-summary'>
        <div class='attendance-item'>
          <strong>{{this.attendance.hadir}}</strong>
          <span>Hadir</span>
        </div>
        <div class='attendance-item'>
          <strong>{{this.attendance.izin}}</strong>
          <span>Izin</span>
        </div>
        <div class='attendance-item'>
          <strong>{{this.attendance.sakit}}</strong>
          <span>Sakit</span>
        </div>
        <div class='attendance-item'>
          <strong>{{this.attendance.alpha}}</strong>
          <span>Alpha</span>
        </div>
        <div class='attendance-item'>
          <strong>{{this.attendance.total}}</strong>
          <span>Total Pertemuan</span>
        </div>
      </div>

      {{#if this.hasRemark}}
      <div style='margin-top: 15px; padding: 15px; background: #e8f4fd; border-left: 4px solid #3498db; border-radius: 4px;'>
        <strong style='color: #2c3e50; display: block; margin-bottom: 8px;'>Catatan Akademik:</strong>
        <p style='color: #555; margin: 0; line-height: 1.6;'>{{this.academicRemark}}</p>
      </div>
      {{/if}}
    {{/each}}

    <div class='footer'>
      <p>Tanggal: {{today}}</p>
      <div class='signature'>
        <p>Kepala Sekolah</p>
        <br /><br /><br />
        <p>____________________</p>
      </div>
    </div>
  </body>
</html>