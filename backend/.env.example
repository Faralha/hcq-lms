# ⚠️ SECURITY WARNING:
# This is a TEMPLATE file. Copy to .env and change ALL values!
# NEVER commit your actual .env file to version control!
# NEVER use these default values in production!

# Database
# PRODUCTION: Use strong password and secure connection
DATABASE_URL="postgresql://username:CHANGE_THIS_PASSWORD@localhost:5432/hcq_lms?schema=public"

# JWT Secret
# PRODUCTION: Generate with: openssl rand -base64 64
# This MUST be a long, random, cryptographically secure string!
JWT_SECRET="CHANGE_THIS_TO_RANDOM_64_CHAR_STRING_IN_PRODUCTION"
JWT_EXPIRATION="7d"

# Email Configuration
# For Local Development: Use Mailpit
# For Production: Use Gmail, SendGrid, or other email service
EMAIL_HOST="localhost"          # Use "mailpit" if NestJS runs in Docker
EMAIL_PORT=1025
EMAIL_SECURE=false
EMAIL_IGNORE_TLS=true
EMAIL_FROM='"No Reply" <noreply@hcq.com>'
FRONTEND_URL="http://localhost:3000"

# OPTIONAL: For Production Email Service (Gmail, custom SMTP, etc)
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASSWORD="your-app-specific-password"  # Use app-specific password, not your Gmail password!
# EMAIL_SERVICE="gmail"  # or use EMAIL_HOST/EMAIL_PORT for custom SMTP

# Application
PORT=4000 # port 3000 clashes with frontend
NODE_ENV="development"  # Set to "production" when deploying

# File Upload
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR="./uploads"

# Redis Config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# S3 Config
S3_ENDPOINT="storage.domain.com"
S3_PORT=443 # Change accordingly
S3_USE_SSL=true
S3_ACCESS_KEY="USERNAME"
S3_SECRET_KEY="SECRET_KEY"
S3_BUCKET_NAME="uploads"

# ═══════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT CHECKLIST:
# ═══════════════════════════════════════════════════════════
# [ ] Changed DATABASE_URL with strong password
# [ ] Generated secure JWT_SECRET (64+ chars)
# [ ] Set NODE_ENV=production
# [ ] Changed all default user passwords from seed file
# [ ] Configured SMTP with app-specific password
# [ ] Enabled HTTPS/TLS
# [ ] Set up database backups
# [ ] Configured CORS for specific origins
# [ ] Set up rate limiting
# [ ] Read SECURITY.md for complete checklist
# ═══════════════════════════════════════════════════════════

